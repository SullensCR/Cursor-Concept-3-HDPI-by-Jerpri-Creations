; Author: JepriCreations
; Website: https://jepricreations.com
[Version]
signature="$Windows NT$"

[DefaultInstall]
CopyFiles = Scheme.Cur
AddReg    = Scheme.Reg, Wreg

[DefaultInstall.NT]
CopyFiles = Scheme.Cur
AddReg    = Scheme.Reg, Wreg

[DestinationDirs]
Scheme.Cur = 16412,"%CUR_DIR%"

[SourceDisksNames]
1 = "Default Cursor Files",,,..\..\assets\yogurt
2 = "Ani Cursor Files",,,..\..\assets\yogurt

[SourceDisksFiles]
"arrow.cur" = 1
"help.cur" = 1
"crosshair.cur" = 1
"nwpen.cur" = 1
"no.cur" = 1
"sizens.cur" = 1
"sizewe.cur" = 1
"sizenwse.cur" = 1
"sizenesw.cur" = 1
"sizeall.cur" = 1
"uparrow.cur" = 1
"hand.cur" = 1
"ibeam.cur" = 1
"pin.cur" = 1
"person.cur" = 1
"appstarting.ani" = 2
"wait.ani" = 2

[Scheme.Reg]
HKCU,"Control Panel\Cursors\Schemes","%SCHEME_NAME%",,%16412%\%CUR_DIR%\%arrow%,%16412%\%CUR_DIR%\%help%,%16412%\%CUR_DIR%\%appstarting%,%16412%\%CUR_DIR%\%wait%,%16412%\%CUR_DIR%\%crosshair%,%16412%\%CUR_DIR%\%ibeam%,%16412%\%CUR_DIR%\%nwpen%,%16412%\%CUR_DIR%\%no%,%16412%\%CUR_DIR%\%sizens%,%16412%\%CUR_DIR%\%sizewe%,%16412%\%CUR_DIR%\%sizenwse%,%16412%\%CUR_DIR%\%sizenesw%,%16412%\%CUR_DIR%\%sizeall%,%16412%\%CUR_DIR%\%uparrow%,%16412%\%CUR_DIR%\%hand%,%16412%\%CUR_DIR%\%person%,%16412%\%CUR_DIR%\%pin%

[Wreg]
HKCU,"Control Panel\Cursors",,0x00020000,"%SCHEME_NAME%"
HKCU,"Control Panel\Cursors",AppStarting,0x00020000,"%16412%\%CUR_DIR%\%appstarting%"
HKCU,"Control Panel\Cursors",Arrow,0x00020000,"%16412%\%CUR_DIR%\%arrow%"
HKCU,"Control Panel\Cursors",crosshair,0x00020000,"%16412%\%CUR_DIR%\%crosshair%"
HKCU,"Control Panel\Cursors",precisionhair,0x00020000,"%16412%\%CUR_DIR%\%crosshair%"
HKCU,"Control Panel\Cursors",Hand,0x00020000,"%16412%\%CUR_DIR%\%hand%"
HKCU,"Control Panel\Cursors",Help,0x00020000,"%16412%\%CUR_DIR%\%help%"
HKCU,"Control Panel\Cursors",IBeam,0x00020000,"%16412%\%CUR_DIR%\%ibeam%"
HKCU,"Control Panel\Cursors",No,0x00020000,"%16412%\%CUR_DIR%\%no%"
HKCU,"Control Panel\Cursors",NWPen,0x00020000,"%16412%\%CUR_DIR%\%nwpen%"
HKCU,"Control Panel\Cursors",SizeAll,0x00020000,"%16412%\%CUR_DIR%\%sizeall%"
HKCU,"Control Panel\Cursors",SizeNESW,0x00020000,"%16412%\%CUR_DIR%\%sizenesw%"
HKCU,"Control Panel\Cursors",SizeNS,0x00020000,"%16412%\%CUR_DIR%\%sizens%"
HKCU,"Control Panel\Cursors",SizeNWSE,0x00020000,"%16412%\%CUR_DIR%\%sizenwse%"
HKCU,"Control Panel\Cursors",SizeWE,0x00020000,"%16412%\%CUR_DIR%\%sizewe%"
HKCU,"Control Panel\Cursors",UpArrow,0x00020000,"%16412%\%CUR_DIR%\%uparrow%"
HKCU,"Control Panel\Cursors",Wait,0x00020000,"%16412%\%CUR_DIR%\%wait%"
HKCU,"Control Panel\Cursors",Person,0x00020000,"%16412%\%CUR_DIR%\%person%"
HKCU,"Control Panel\Cursors",Pin,0x00020000,"%16412%\%CUR_DIR%\%pin%"
HKLM,"SOFTWARE\Microsoft\Windows\CurrentVersion\Runonce\Setup\","",,"rundll32.exe shell32.dll,Control_RunDLL main.cpl @0,1"

[Scheme.Cur]
"arrow.cur"
"help.cur"
"crosshair.cur"
"nwpen.cur"
"no.cur"
"sizens.cur"
"sizewe.cur"
"sizenwse.cur"
"sizenesw.cur"
"sizeall.cur"
"uparrow.cur"
"hand.cur"
"ibeam.cur"
"pin.cur"
"person.cur"
"appstarting.ani"
"wait.ani"

[Strings]
CUR_DIR     = "Cursors\JepriCreations\Cursor Concept 3 HDPi Yogurt"
SCHEME_NAME = "Cursor Concept 3 HDPi Yogurt"
AUTHOR      = "JepriCreations"
WEBSITE     = "https://jepricreations.com"
arrow		= "arrow.cur"
help		= "help.cur"
appstarting		= "appstarting.ani"
wait		= "wait.ani"
crosshair		= "crosshair.cur"
nwpen		= "nwpen.cur"
ibeam		= "ibeam.cur"
no		= "no.cur"
sizens		= "sizens.cur"
sizewe		= "sizewe.cur"
sizenwse		= "sizenwse.cur"
sizenesw		= "sizenesw.cur"
sizeall		= "sizeall.cur"
uparrow		= "uparrow.cur"
hand		= "hand.cur"
person		= "person.cur"
pin		= "pin.cur"
